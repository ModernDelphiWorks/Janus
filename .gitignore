# Workspace-local development artifacts (pipeline-contract.md mandate)
.local-readonly/

# Delphi IDE-generated configs and compiled resources
*.cfg
*.drc
*.dres

# Resource definition files generated by IDE/wizard (scoped to avoid hiding source .rc files elsewhere)
Projects/**/*.rc

# Runtime DLLs co-located with example and test executables (must stay in place)
Examples/**/*.dll
Test/**/*.dll

# Generated DUnitX test result artifacts
Test/Delphi/*.xml
Test/Delphi/*.txt
Test/Delphi/*.bat

# Compiled Lazarus output directory
Test/Lazarus/output/

# Compiled DLL Framework object/static-lib artifacts
Projects/Janus DLL Framework/*.o
Projects/Janus DLL Framework/*.a

# Delphi compile artifacts (object files, version-resources, manifests)
*.obj
*.vrc
*.$manifest

# Cygwin/MSYS crash dumps
**/bash.exe.stackdump

# Local test result and coverage output directories
Test/Delphi/results_*/
/coverage_*/

# Per-machine Oracle network config
Test/Delphi/tnsnames.ora

# Boss package manager files
!boss.json
!boss-lock.json

# PubDelphi manifest (tracked, like boss.json)
!pubdelphi.json
